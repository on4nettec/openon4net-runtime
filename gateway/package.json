{
  "name": "@o2n/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../.env dist/index.js",
    "migrate": "node --env-file=../.env scripts/migrate.mjs",
    "backup": "node --env-file=../.env scripts/backup-db.mjs",
    "restore": "node --env-file=../.env scripts/restore-db.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.687.0",
    "@aws-sdk/s3-request-presigner": "^3.687.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@fastify/websocket": "^11.3.0",
    "@node-rs/argon2": "^2.0.2",
    "@node-saml/node-saml": "^5.1.0",
    "@o2n/governance": "workspace:*",
    "@o2n/llm-providers": "workspace:*",
    "@o2n/shared": "workspace:*",
    "adm-zip": "^0.5.16",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
