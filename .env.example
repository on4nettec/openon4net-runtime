# Copy to .env and fill in real values before running docker compose up.
#
# SINGLE SOURCE OF TRUTH: this one file is read both by `pnpm dev` (gateway's
# package.json points --env-file at ../.env) and by docker-compose.yml's
# `env_file: .env`. Don't create a second .env under gateway/ — it will drift
# out of sync (e.g. mismatched JWT_SECRET looks like "invalid token" and is a
# pain to debug).
#
# postgres/redis/minio are NOT started by docker-compose.yml — they're
# expected to already be running as separate containers (or a remote host).
# POSTGRES_*/MINIO_* below just need to match whatever those already are.

# --- postgres (must match your already-running Postgres instance) ---
POSTGRES_DB=o2n
POSTGRES_USER=o2n
POSTGRES_PASSWORD=o2n_dev_password

# --- minio (must match your already-running MinIO instance; not yet consumed by any
# gateway code, so these aren't in env.ts's schema yet either — add them there
# when something actually reads MinIO). Same Mode A/B split as DATABASE_URL/REDIS_URL below.
MINIO_ROOT_USER=o2n_minio
MINIO_ROOT_PASSWORD=o2n_minio_password
MINIO_BUCKET=o2n-files

# Mode A: gateway runs in Docker (docker compose up)
MINIO_ENDPOINT=host.docker.internal
MINIO_PORT=9500
# Mode B: gateway runs directly on the host (pnpm dev, no Docker)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9500
MINIO_USE_SSL=false

# --- gateway ---
PORT=4000

# Exactly ONE of the two blocks below should be uncommented, depending on how
# you're currently running the gateway. `localhost` inside a Docker container
# means the container itself, not the host, so the two modes need different
# hostnames to reach the same postgres/redis containers.

# Mode A: gateway runs in Docker (docker compose up)
DATABASE_URL=postgres://o2n:o2n_dev_password@host.docker.internal:5532/o2n
REDIS_URL=redis://host.docker.internal:6479

# Mode B: gateway runs directly on the host (pnpm dev, no Docker)
# DATABASE_URL=postgres://o2n:o2n_dev_password@localhost:5532/o2n
# REDIS_URL=redis://localhost:6479

JWT_SECRET=change-me-to-a-long-random-string
DEV_API_KEY=change-me-dev-only-api-key

# --- auth (RT-014..018, multi-method — docs/spect/02_ARCHITECTURE/16-authentication-modes.md) ---
# The built Docker image bakes NODE_ENV=production (Dockerfile.gateway) —
# dev_api_key refuses to start unless this is overridden to a non-production
# value AND AUTH_ALLOW_DEV_METHODS=true (see gateway/src/env.ts).
NODE_ENV=development
#
# Comma-separated list, at least one required. Example: password,oauth,magic_link
AUTH_METHODS_ENABLED=dev_api_key,password
AUTH_METHODS_DEFAULT=password
AUTH_ALLOW_DEV_METHODS=true
PASSWORD_HASHER=argon2id
PASSWORD_MIN_LENGTH=10
#
# Magic-link (requires SMTP) — add magic_link to AUTH_METHODS_ENABLED once set:
# EMAIL_FROM=no-reply@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=...
#
# OAuth/OIDC (SSO-lite) — add oauth to AUTH_METHODS_ENABLED once set.
# OAUTH_CALLBACK_URL is a BASE url (no path); the gateway appends
# /v1/auth/oauth/<provider>/callback itself — register that full URL per
# provider in each OAuth app's console.
# OAUTH_PROVIDERS=google,github
# OAUTH_GOOGLE_CLIENT_ID=...
# OAUTH_GOOGLE_CLIENT_SECRET=...
# OAUTH_GITHUB_CLIENT_ID=...
# OAUTH_GITHUB_CLIENT_SECRET=...
# OAUTH_CALLBACK_URL=http://localhost:4000

# BYOK: exactly one provider is active per deployment (docs/spect/02_ARCHITECTURE/14-monorepo-layout.md v2 §3)
# LLM_PROVIDER = anthropic | openai | deepseek | ollama
#   anthropic: LLM_API_KEY=sk-ant-...,           LLM_MODEL=claude-3-5-sonnet-20241022
#   openai:    LLM_API_KEY=sk-...,               LLM_MODEL=gpt-4o
#   deepseek:  LLM_API_KEY=<deepseek api key>,   LLM_MODEL=deepseek-chat
#   ollama:    LLM_API_KEY=ollama (unchecked),   LLM_MODEL=<a model you've pulled, e.g. llama3.1>
# LLM_BASE_URL is optional — only set it to override each provider's default
# (e.g. a self-hosted DeepSeek-compatible gateway, or Ollama on a remote host).
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_BASE_URL=http://localhost:11434/v1

# Cost/human-in-the-loop threshold — requests estimated above this sit in
# approval_queue until a human approves them (build pack §4.3).
APPROVAL_THRESHOLD_CENTS=2000

SHORT_MEMORY_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=100

# AES-256-GCM master key for encrypting per-organization BYOK provider
# overrides (llm_configs.api_key_encrypted) that admins set from the
# dashboard's Settings page instead of editing LLM_API_KEY above + restarting.
# Must be exactly 64 hex chars (32 bytes). Generate with: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# --- secrets/kms (planned: RT-011, multi-provider) ---
# Comma-separated list of enabled providers (decrypt can support multiple).
# SECRETS_KMS_ENABLED_PROVIDERS=env,vault
#
# Provider used for *new* encrypt/write operations.
# SECRETS_KMS_PRIMARY_PROVIDER=env
#
# Safety: in production, disallow env master keys unless explicitly allowed.
# SECRETS_ALLOW_ENV_KMS_IN_PROD=false
#
# Vault (Transit) settings:
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=change-me
# VAULT_TRANSIT_KEY=o2n-config

# Optional: enables semantic memory search (migrations/0008_vector_search.sql,
# needs the pgvector extension — use the pgvector/pgvector:pg16 Postgres
# image). Only works when LLM_PROVIDER=openai or ollama (both speak the
# OpenAI-compatible /v1/embeddings endpoint); anthropic/deepseek have no
# embeddings API, so leave this unset for those and memory search just stays
# on the plain ILIKE search it always had. For ollama:
# `ollama pull nomic-embed-text` (768 dims, matches the migration's column
# width — a different model needs a matching column-width migration).
# EMBEDDING_MODEL=nomic-embed-text

# --- RT-083: i18n ---
# Optional — 'en' (the reference locale) always works with this unset. Any
# other language 400s with a clear "not configured" error until this is set.
# Deliberately separate from LLM_API_KEY/LLM_PROVIDER above — locale
# generation is deployment-global, not a per-org chat cost.
# LOCALE_AI_API_KEY=sk-ant-...
# LOCALE_AI_MODEL=claude-3-5-haiku-20241022

# --- web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
